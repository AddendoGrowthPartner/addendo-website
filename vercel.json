{
  "framework": "astro",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/en/home",
      "destination": "/en/",
      "permanent": true
    },
    {
      "source": "/en/home/",
      "destination": "/en/",
      "permanent": true
    },
    {
      "source": "/pickup/:code*",
      "destination": "/",
      "permanent": true
    }
  ]
}
