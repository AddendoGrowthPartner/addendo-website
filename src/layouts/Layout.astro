---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
  canonical?: string;
  preloadImage?: string;
  lang?: 'es' | 'en';
  alternates?: { es: string; en: string };
}

const siteUrl = 'https://addendo.io';
const defaultOgImage = 'https://res.cloudinary.com/dokzw376u/image/upload/f_auto,q_auto/v1774995924/VECTOR_ADDENDO_FINAL_zuw6te.jpg';
const defaultPreloadImage = 'https://res.cloudinary.com/dokzw376u/image/fetch/f_auto,q_auto,w_1200/https://images.unsplash.com/photo-1460925895917-afdab827c52f';

const {
  title,
  description,
  ogImage = defaultOgImage,
  canonical,
  preloadImage = defaultPreloadImage,
  lang = 'es',
  alternates,
} = Astro.props;

const currentUrl = new URL(Astro.url.pathname, siteUrl).toString();
const resolvedCanonical = canonical ?? currentUrl;

const defaultTitleEs = 'Addendo | Tu sistema completo de crecimiento y ventas';
const defaultTitleEn = 'Addendo | Your Complete Growth and Sales System';
const defaultDescEs = 'Addendo es el sistema completo que convierte tu negocio en una máquina de ventas — presencia digital, campañas, contenido, reputación y clientes nuevos cada semana.';
const defaultDescEn = 'Addendo is the complete system that turns your business into a sales machine — digital presence, campaigns, content, reputation, and new customers every week.';

const resolvedTitle = title ?? (lang === 'en' ? defaultTitleEn : defaultTitleEs);
const resolvedDescription = description ?? (lang === 'en' ? defaultDescEn : defaultDescEs);
const ogLocale = lang === 'en' ? 'en_US' : 'es_US';

const alternateEs = alternates?.es ? new URL(alternates.es, siteUrl).toString() : null;
const alternateEn = alternates?.en ? new URL(alternates.en, siteUrl).toString() : null;
---

<!doctype html>
<html lang={lang} data-lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{resolvedTitle}</title>
    <meta name="description" content={resolvedDescription} />
    <meta name="robots" content="index, follow" />
    <link rel="canonical" href={resolvedCanonical} />

    {alternateEs && <link rel="alternate" hreflang="es" href={alternateEs} />}
    {alternateEn && <link rel="alternate" hreflang="en" href={alternateEn} />}
    {alternateEs && <link rel="alternate" hreflang="x-default" href={alternateEs} />}

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={resolvedCanonical} />
    <meta property="og:title" content={resolvedTitle} />
    <meta property="og:description" content={resolvedDescription} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:locale" content={ogLocale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={resolvedTitle} />
    <meta name="twitter:description" content={resolvedDescription} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Schema.org -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "ProfessionalService",
      "name": "Addendo Growth Partner",
      "url": siteUrl,
      "logo": ogImage,
      "description": resolvedDescription,
      "areaServed": "US",
      "serviceType": ["Digital Marketing", "Sales Growth", "Web Development", "SEO", "Advertising"],
      "contactPoint": {
        "@type": "ContactPoint",
        "email": "admin@addendo.io",
        "contactType": "sales"
      }
    })} />

    <!-- Preconnect -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Hero image preload -->
    <link rel="preload" as="image" href={preloadImage} fetchpriority="high" />

    <!-- Fonts (non-blocking) -->
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300&family=Inter:wght@300;400;500;600&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,400;1,9..144,300&family=Inter:wght@300;400;500;600&display=swap" /></noscript>
    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Teko:wght@700&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link href="https://fonts.googleapis.com/css2?family=Teko:wght@700&display=swap" rel="stylesheet" /></noscript>

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- GTM + GA4 — carga diferida para no bloquear renderizado -->
    <script is:inline>
      function loadGTM() {
        if (window.gtmLoaded) return;
        window.gtmLoaded = true;
        // GA4
        var g = document.createElement('script');
        g.async = true;
        g.src = 'https://www.googletagmanager.com/gtag/js?id=G-C7DCM1NZ6P';
        document.head.appendChild(g);
        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());
        gtag('config', 'G-C7DCM1NZ6P');
        // GTM
        (function(w,d,s,l,i){w[l]=w[l]||[];w[l].push({'gtm.start':
        new Date().getTime(),event:'gtm.js'});var f=d.getElementsByTagName(s)[0],
        j=d.createElement(s),dl=l!='dataLayer'?'&l='+l:'';j.async=true;j.src=
        'https://www.googletagmanager.com/gtm.js?id='+i+dl;f.parentNode.insertBefore(j,f);
        })(window,document,'script','dataLayer','GTM-WSBBDQ4L');
      }
      setTimeout(loadGTM, 3000);
      document.addEventListener('click', loadGTM, {once: true});
      document.addEventListener('scroll', loadGTM, {once: true});
      document.addEventListener('touchstart', loadGTM, {once: true});
    </script>

    <!-- Microsoft Clarity -->
    <script is:inline type="text/javascript">
      (function(c,l,a,r,i,t,y){
        c[a]=c[a]||function(){(c[a].q=c[a].q||[]).push(arguments)};
        t=l.createElement(r);t.async=1;t.src="https://www.clarity.ms/tag/"+i;
        y=l.getElementsByTagName(r)[0];y.parentNode.insertBefore(t,y);
      })(window, document, "clarity", "script", "w6865bxodj");
    </script>
  </head>
  <body>
    <!-- GTM noscript -->
    <noscript><iframe src="https://www.googletagmanager.com/ns.html?id=GTM-WSBBDQ4L" height="0" width="0" style="display:none;visibility:hidden"></iframe></noscript>

    <slot />
  </body>
</html>
