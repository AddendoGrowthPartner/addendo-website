---
import Layout from './Layout.astro';

interface Props {
  titleEs: string;
  titleEn: string;
  descEs: string;
  descEn: string;
  category: string;
  date: string;            // YYYY-MM-DD
  readTime: number;        // minutos
  heroImg: string;         // URL completa o ruta relativa al sitio
  heroAlt?: string;        // descriptivo SEO; si no se pasa, hero queda decorativo
  heroWidth?: number;      // default 1200
  heroHeight?: number;     // default 800
  slug: string;
  lang?: 'es' | 'en';      // default 'es' — determina cuál par title/desc usar
  alternates?: { es: string; en: string };
  author?: { type: 'Person' | 'Organization'; name: string; url?: string };
  tzOffset?: string;       // e.g. '-04:00' (EDT), '-05:00' (EST)
}

const {
  titleEs,
  titleEn,
  descEs,
  descEn,
  category,
  date,
  readTime,
  heroImg,
  heroAlt,
  heroWidth = 1200,
  heroHeight = 800,
  slug,
  lang = 'es',
  alternates,
  author = { type: 'Organization', name: 'Addendo Growth Partner', url: 'https://addendo.io' },
  tzOffset = '-04:00',
} = Astro.props;

const isoDate = `${date}T00:00:00${tzOffset}`;
const schemaAuthor = author.url
  ? { "@type": author.type, "name": author.name, "url": author.url }
  : { "@type": author.type, "name": author.name };

const SITE = 'https://addendo.io';

const path = lang === 'en' ? `/en/blog/${slug}/` : `/blog/${slug}`;
const canonical = `${SITE}${path}`;
const ogImage = heroImg.startsWith('http') ? heroImg : `${SITE}${heroImg}`;

const title = lang === 'en' ? titleEn : titleEs;
const description = lang === 'en' ? descEn : descEs;
const metaTitle = `${title} | Addendo`;

const monthsEs = ['enero','febrero','marzo','abril','mayo','junio','julio','agosto','septiembre','octubre','noviembre','diciembre'];
const monthsEn = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const [yyyy, mm] = date.split('-');
const monthIdx = parseInt(mm, 10) - 1;
const monthYear = lang === 'en'
  ? `${monthsEn[monthIdx]} ${yyyy}`
  : `${monthsEs[monthIdx][0].toUpperCase()}${monthsEs[monthIdx].slice(1)} ${yyyy}`;

const backLabel = lang === 'en' ? 'Back to home' : 'Volver al inicio';
const readLabel = lang === 'en' ? `${readTime} min read` : `${readTime} min de lectura`;
const ctaText = lang === 'en'
  ? 'Ready to automate your marketing with AI?'
  : '¿Listo para automatizar tu marketing con IA?';
const ctaBtn = lang === 'en' ? 'Schedule your free call' : 'Agenda tu llamada gratuita';
const allArticlesLabel = lang === 'en' ? 'View all articles' : 'Ver todos los artículos';
const allArticlesHref = lang === 'en' ? '/en/blog/' : '/blog';
---

<Layout
  title={metaTitle}
  description={description}
  ogImage={ogImage}
  canonical={canonical}
  preloadImage={heroImg}
  lang={lang}
  alternates={alternates}
>
  <article class="blog-post">
    <!-- Hero -->
    <header class="blog-hero">
      <img
        src={heroImg}
        alt={heroAlt ?? ''}
        width={heroWidth}
        height={heroHeight}
        fetchpriority="high"
        decoding="async"
        aria-hidden={heroAlt ? undefined : 'true'}
      />
      <div class="blog-hero-overlay"></div>
      <div class="blog-hero-inner">
        <a href={lang === 'en' ? '/en/' : '/'} class="blog-back" aria-label={backLabel}>
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <line x1="19" y1="12" x2="5" y2="12"></line>
            <polyline points="12 19 5 12 12 5"></polyline>
          </svg>
          <span>{backLabel}</span>
        </a>

        <span class="blog-category">{category}</span>

        <h1 class="blog-title">{title}</h1>

        <div class="blog-meta">
          <time datetime={date}>{monthYear}</time>
          <span class="blog-meta-sep" aria-hidden="true">•</span>
          <span>{readLabel}</span>
        </div>
      </div>
    </header>

    <div class="blog-article-wrap">
      <slot />

      <!-- CTA estándar -->
      <aside class="blog-cta">
        <p class="blog-cta-text">{ctaText}</p>
        <a href={lang === 'en' ? '/en/#contacto' : '/#contacto'} class="btn-gold text-base md:text-lg">
          <span>{ctaBtn}</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
      </aside>

      <div style="text-align:center; margin-top: 2rem;">
        <a href={allArticlesHref} style="color: #C9A84C; text-decoration: none; font-size: 0.9rem; border: 1px solid rgba(201,168,76,0.3); padding: 0.75rem 1.5rem; border-radius: 9999px;">
          &larr; {allArticlesLabel}
        </a>
      </div>
    </div>
  </article>

  <!-- Article schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": title,
    "description": description,
    "image": ogImage,
    "datePublished": isoDate,
    "dateModified": isoDate,
    "author": schemaAuthor,
    "publisher": {
      "@type": "Organization",
      "name": "Addendo Growth Partner",
      "logo": { "@type": "ImageObject", "url": "https://res.cloudinary.com/dokzw376u/image/upload/f_auto,q_auto/v1774995924/VECTOR_ADDENDO_FINAL_zuw6te.jpg" }
    },
    "mainEntityOfPage": { "@type": "WebPage", "@id": canonical },
    "articleSection": category,
    "inLanguage": lang
  })} />
</Layout>
