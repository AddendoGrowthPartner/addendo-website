---
import Layout from '../../layouts/Layout.astro';

const title = 'Blog | Addendo Growth Partner';
const description = 'Estrategias de marketing digital, SEO, redes sociales e inteligencia artificial para hacer crecer tu negocio.';

const posts = [
  {
    title: 'Cómo duplicar tus leads en 30 días con Google Ads',
    image: '/blog/google-ads-leads.jpg',
    category: 'Marketing Digital',
    date: 'Abril 2026',
    excerpt: 'Las estrategias exactas que usamos para multiplicar los resultados de nuestros clientes con Google Ads.',
    url: '/blog/duplicar-leads-google-ads',
  },
  {
    title: 'Por qué tu negocio necesita estar en TikTok en 2026',
    image: '/blog/tiktok-business.jpg',
    category: 'Redes Sociales',
    date: 'Abril 2026',
    excerpt: 'TikTok ya no es solo para jóvenes — es el canal de mayor crecimiento para negocios hoy.',
    url: '/blog/tiktok-negocios-2026',
  },
  {
    title: 'SEO Local: Aparece primero cuando te buscan en tu ciudad',
    image: '/blog/seo-local.jpg',
    category: 'SEO',
    date: 'Abril 2026',
    excerpt: 'Cómo posicionar tu negocio en Google cuando clientes cercanos buscan lo que ofreces.',
    url: '/blog/seo-local-aparecer-primero',
  },
];
---

<Layout title={title} description={description} canonical="https://addendo.io/blog">
  <main style="background: #080F24; min-height: 100vh; padding-top: 6rem;">
    <!-- Header -->
    <section style="padding: 4rem 1.5rem 2rem; text-align: center; max-width: 800px; margin: 0 auto;">
      <span style="display: inline-block; font-family: 'Inter', sans-serif; font-size: 0.75rem; font-weight: 600; letter-spacing: 0.15em; text-transform: uppercase; color: #C9A84C; border: 1px solid rgba(201,168,76,0.3); border-radius: 9999px; padding: 0.4rem 1.2rem; margin-bottom: 1.5rem;">
        &bull; BLOG
      </span>
      <h1 style="font-family: 'Fraunces', serif; font-size: clamp(2rem, 5vw, 3.2rem); font-weight: 400; color: white; line-height: 1.2; margin: 0 0 1rem;">
        Estrategias que transforman negocios
      </h1>
      <p style="font-family: 'Inter', sans-serif; font-size: 1.1rem; color: rgba(255,255,255,0.55); line-height: 1.7; max-width: 640px; margin: 0 auto;">
        Insights, tendencias y casos de éxito para hacer crecer tu negocio con marketing e inteligencia artificial.
      </p>
    </section>

    <!-- Articles grid -->
    <section style="max-width: 1200px; margin: 0 auto; padding: 2rem 1.5rem 5rem;">
      <div class="blog-grid">
        {posts.map((post) => (
          <a href={post.url} class="blog-card">
            <div class="blog-card-img">
              <img src={post.image} alt={post.title} width="800" height="400" loading="lazy" />
              <div class="blog-card-img-overlay" />
            </div>
            <div class="blog-card-body">
              <span class="blog-card-badge">{post.category}</span>
              <h2 class="blog-card-title">{post.title}</h2>
              <p class="blog-card-excerpt">{post.excerpt}</p>
              <div class="blog-card-footer">
                <span class="blog-card-date">{post.date}</span>
                <span class="blog-card-cta">Leer artículo &rarr;</span>
              </div>
            </div>
          </a>
        ))}
      </div>
    </section>
  </main>

  <style>
    .blog-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 2rem;
    }
    @media (min-width: 768px) {
      .blog-grid {
        grid-template-columns: repeat(3, 1fr);
      }
    }
    .blog-card {
      display: block;
      border-radius: 1rem;
      overflow: hidden;
      border: 1px solid rgba(201,168,76,0.15);
      background: rgba(26,26,46,0.6);
      backdrop-filter: blur(16px);
      text-decoration: none;
      transition: transform 0.3s, border-color 0.3s;
    }
    .blog-card:hover {
      transform: translateY(-4px);
      border-color: rgba(201,168,76,0.4);
    }
    .blog-card-img {
      position: relative;
      height: 12rem;
      overflow: hidden;
    }
    .blog-card-img img {
      width: 100%;
      height: 100%;
      object-fit: cover;
      transition: transform 0.5s;
    }
    .blog-card:hover .blog-card-img img {
      transform: scale(1.05);
    }
    .blog-card-img-overlay {
      position: absolute;
      inset: 0;
      background: linear-gradient(to top, rgba(26,26,46,0.8), transparent);
    }
    .blog-card-body {
      padding: 1.5rem;
    }
    .blog-card-badge {
      display: inline-block;
      padding: 0.25rem 0.75rem;
      border-radius: 9999px;
      font-size: 0.7rem;
      font-weight: 600;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: #C9A84C;
      background: rgba(201,168,76,0.1);
      border: 1px solid rgba(201,168,76,0.2);
      margin-bottom: 1rem;
    }
    .blog-card-title {
      font-family: 'Fraunces', serif;
      font-size: 1.2rem;
      font-weight: 700;
      color: white;
      line-height: 1.35;
      margin: 0 0 0.75rem;
    }
    .blog-card-excerpt {
      font-size: 0.875rem;
      color: rgba(255,255,255,0.5);
      line-height: 1.6;
      margin: 0 0 1rem;
    }
    .blog-card-footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .blog-card-date {
      font-size: 0.75rem;
      color: rgba(255,255,255,0.3);
    }
    .blog-card-cta {
      font-size: 0.875rem;
      font-weight: 600;
      color: #C9A84C;
    }
  </style>
</Layout>
