---
// Static Infrastructure section — ported from Infrastructure.tsx.
// Bilingual via data-lang-es / data-lang-en spans (global CSS rule toggles).
// Animations via CSS @keyframes triggered by a tiny IntersectionObserver script.
import es from '../i18n/es';
import en from '../i18n/en';

const items = es.infra.items.map((it, i) => ({ es: it, en: en.infra.items[i] }));

// The original component used 4 inline SVGs kept in a local array. Copied here
// as a static list so we can iterate alongside items[].
const iconPaths = [
  'M19.428 15.428a2 2 0 00-1.022-.547l-2.387-.477a6 6 0 00-3.86.517l-.318.158a6 6 0 01-3.86.517L6.05 15.21a2 2 0 00-1.806.547M8 4h8l-1 1v5.172a2 2 0 00.586 1.414l5 5c1.26 1.26.367 3.414-1.415 3.414H4.828c-1.782 0-2.674-2.154-1.414-3.414l5-5A2 2 0 009 10.172V5L8 4z',
  'M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z',
  'M13 10V3L4 14h7v7l9-11h-7z',
  'M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z',
];
---

<section id="infraestructura" class="section-pad relative" style="background: #080F24">
  <div class="max-w-6xl mx-auto">
    <div class="inf-i text-center mb-10">
      <h2 class="font-display text-3xl sm:text-4xl md:text-5xl font-normal mb-4">
        <span data-lang-es>{es.infra.title1}</span>
        <span data-lang-en>{en.infra.title1}</span>
        <span class="gold-gradient-text" data-lang-es>{es.infra.titleGold}</span>
        <span class="gold-gradient-text" data-lang-en>{en.infra.titleGold}</span>
      </h2>
      <p class="text-white/40 text-lg max-w-xl mx-auto">
        <span data-lang-es>{es.infra.subtitle}</span>
        <span data-lang-en>{en.infra.subtitle}</span>
      </p>
    </div>
    <div class="grid md:grid-cols-2 gap-5">
      {items.map(({ es: s, en: e }, i) => (
        <div class="inf-i glass-card p-8 flex gap-5 items-start">
          <div class="text-gold shrink-0" aria-hidden="true">
            <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d={iconPaths[i]} />
            </svg>
          </div>
          <div>
            <h3 class="text-lg font-bold text-white mb-2">
              <span data-lang-es>{s.title}</span>
              <span data-lang-en>{e.title}</span>
            </h3>
            <p class="text-white/45 text-sm leading-relaxed">
              <span data-lang-es>{s.desc}</span>
              <span data-lang-en>{e.desc}</span>
            </p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .inf-i {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.6s ease-out, transform 0.6s ease-out;
    will-change: opacity, transform;
  }
  .inf-i.is-visible { opacity: 1; transform: none; }
  @media (max-width: 767px) {
    .inf-i { opacity: 1; transform: none; transition: none; }
  }
  @media (prefers-reduced-motion: reduce) {
    .inf-i { opacity: 1; transform: none; transition: none; }
  }
</style>

<script is:inline>
  (function () {
    if (typeof window === 'undefined') return;
    if (window.innerWidth < 768) return;
    if (!('IntersectionObserver' in window)) return;
    var targets = document.querySelectorAll('#infraestructura .inf-i');
    if (!targets.length) return;
    var obs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (!entry.isIntersecting) return;
        entry.target.classList.add('is-visible');
        obs.unobserve(entry.target);
      });
    }, { rootMargin: '0px 0px -20% 0px' });
    targets.forEach(function (t, i) {
      t.style.transitionDelay = (i * 0.08) + 's';
      obs.observe(t);
    });
  })();
</script>
