---
// Pulse.astro — Addendo Pulse: swarm-intelligence simulation section.
// Fully static. Bilingual via data-lang-es/data-lang-en spans toggled
// by the global CSS rules in global.css + the resolver script in Layout.astro.
// All animation is vanilla JS in the <script is:inline> block at the bottom.
---

<section id="pulse" class="section-pad relative overflow-hidden" style="background: #080F24">
  <div class="pulse-bg" aria-hidden="true"></div>

  <div class="relative max-w-6xl mx-auto">

    <!-- ========== PART 1 — COPY ========== -->
    <div class="text-center mb-12 md:mb-16">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border border-gold/30 bg-gold/5 mb-6">
        <span class="pulse-dot" aria-hidden="true"></span>
        <span class="text-gold text-[10px] md:text-xs font-semibold uppercase tracking-[0.2em]">Addendo Pulse &bull; Beta</span>
      </div>

      <h2 class="font-display text-3xl sm:text-4xl md:text-5xl lg:text-6xl font-normal leading-tight mb-6">
        <span data-lang-es>Tu mercado reacciona. Tú decides.<br /><span class="gold-gradient-text italic">Antes de gastar un solo dólar.</span></span>
        <span data-lang-en>Your market reacts. You decide.<br /><span class="gold-gradient-text italic">Before spending a single dollar.</span></span>
      </h2>

      <p class="text-white/55 text-base md:text-xl max-w-3xl mx-auto leading-relaxed">
        <span data-lang-es>Miles de personas virtuales simulan cómo tu audiencia real responderá a tu campaña, tu copy y tu mensaje de ventas — en minutos, no en semanas.</span>
        <span data-lang-en>Thousands of virtual people simulate how your real audience will respond to your campaign, copy and sales message — in minutes, not weeks.</span>
      </p>

      <div class="grid sm:grid-cols-3 gap-4 md:gap-6 max-w-4xl mx-auto mt-10">
        <div class="pulse-bullet flex items-start gap-3 text-left">
          <span class="pulse-check" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </span>
          <p class="text-white/75 text-sm md:text-base leading-snug">
            <span data-lang-es>Optimizamos tu copy de ads antes de lanzar</span>
            <span data-lang-en>We optimize your ad copy before launch</span>
          </p>
        </div>
        <div class="pulse-bullet flex items-start gap-3 text-left">
          <span class="pulse-check" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </span>
          <p class="text-white/75 text-sm md:text-base leading-snug">
            <span data-lang-es>Entrenamos tu agente de ventas con objeciones reales</span>
            <span data-lang-en>We train your sales agent with real objections</span>
          </p>
        </div>
        <div class="pulse-bullet flex items-start gap-3 text-left">
          <span class="pulse-check" aria-hidden="true">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#C9A84C" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
          </span>
          <p class="text-white/75 text-sm md:text-base leading-snug">
            <span data-lang-es>Comparamos varios mensajes y descubrimos cuál convierte más</span>
            <span data-lang-en>We compare multiple messages and discover which converts more</span>
          </p>
        </div>
      </div>
    </div>

    <!-- ========== PART 2 — CANVAS ========== -->
    <div class="pulse-canvas-wrap relative mb-12 md:mb-16">
      <canvas id="pulse-canvas" aria-hidden="true"></canvas>

      <div class="absolute top-3 left-3 md:top-4 md:left-4 flex items-center gap-2 pointer-events-none">
        <span class="inline-block w-1.5 h-1.5 rounded-full bg-gold animate-pulse"></span>
        <span class="text-[9px] md:text-[10px] font-semibold text-gold/60 uppercase tracking-widest">
          <span data-lang-es>Simulación en vivo</span>
          <span data-lang-en>Live simulation</span>
        </span>
      </div>

      <div class="absolute top-3 right-3 md:top-4 md:right-4 text-[9px] md:text-[10px] font-mono text-white/35 tabular-nums pointer-events-none">
        <span id="pulse-counter">1247</span>
        <span data-lang-es> agentes activos</span>
        <span data-lang-en> active agents</span>
      </div>

      <div class="absolute bottom-3 left-3 md:bottom-4 md:left-4 text-[9px] md:text-[10px] font-mono text-white/25 uppercase tracking-widest pointer-events-none">
        pulse_engine.v1.0
      </div>
    </div>

    <!-- ========== PART 3 — METRICS ========== -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 md:gap-10 mb-14 md:mb-20 text-center">
      <div class="pulse-metric">
        <div class="pulse-metric-val gold-gradient-text font-display text-4xl md:text-6xl font-black leading-none" data-target="1000" data-suffix="+">0</div>
        <p class="text-white/40 text-xs md:text-sm mt-3 uppercase tracking-[0.15em]">
          <span data-lang-es>agentes por simulación</span>
          <span data-lang-en>agents per simulation</span>
        </p>
      </div>
      <div class="pulse-metric">
        <div class="pulse-metric-val gold-gradient-text font-display text-4xl md:text-6xl font-black leading-none" data-target="30" data-prefix="< " data-suffix=" min">0</div>
        <p class="text-white/40 text-xs md:text-sm mt-3 uppercase tracking-[0.15em]">
          <span data-lang-es>resultados en minutos</span>
          <span data-lang-en>results in minutes</span>
        </p>
      </div>
      <div class="pulse-metric">
        <div class="pulse-metric-val gold-gradient-text font-display text-4xl md:text-6xl font-black leading-none" data-target="3" data-suffix="x">0</div>
        <p class="text-white/40 text-xs md:text-sm mt-3 uppercase tracking-[0.15em]">
          <span data-lang-es>mejora en conversión</span>
          <span data-lang-en>conversion improvement</span>
        </p>
      </div>
    </div>

    <!-- ========== PART 4 — CTA ========== -->
    <div class="pulse-cta relative p-8 md:p-14 text-center">
      <div class="pulse-cta-bg" aria-hidden="true"></div>
      <div class="relative">
        <h3 class="font-display text-2xl sm:text-3xl md:text-5xl font-normal leading-tight mb-4">
          <span data-lang-es>Simula tu próxima campaña <span class="gold-gradient-text italic">antes de lanzarla.</span></span>
          <span data-lang-en>Simulate your next campaign <span class="gold-gradient-text italic">before launch.</span></span>
        </h3>
        <p class="text-white/60 text-base md:text-lg max-w-2xl mx-auto mb-8">
          <span data-lang-es>30 minutos. Miles de reacciones reales. Cero dólares desperdiciados.</span>
          <span data-lang-en>30 minutes. Thousands of real reactions. Zero wasted dollars.</span>
        </p>
        <a href="#contacto" class="btn-gold text-base md:text-lg inline-flex">
          <span data-lang-es>Quiero mi simulación gratis</span>
          <span data-lang-en>Get my free simulation</span>
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" focusable="false">
            <line x1="5" y1="12" x2="19" y2="12"></line>
            <polyline points="12 5 19 12 12 19"></polyline>
          </svg>
        </a>
        <p class="text-white/35 text-xs md:text-sm mt-5">
          <span data-lang-es>Solo 3 cupos disponibles este mes</span>
          <span data-lang-en>Only 3 spots available this month</span>
        </p>
      </div>
    </div>

  </div>
</section>

<style>
  /* Decorative grid background behind the whole section */
  #pulse .pulse-bg {
    position: absolute;
    inset: 0;
    pointer-events: none;
    background-image:
      linear-gradient(rgba(201,168,76,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(201,168,76,0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 0%, transparent 90%);
    -webkit-mask-image: radial-gradient(ellipse 70% 60% at 50% 50%, black 0%, transparent 90%);
  }

  #pulse .pulse-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #C9A84C;
    box-shadow: 0 0 8px rgba(201,168,76,0.9);
    animation: pulse-beat 1.4s ease-in-out infinite;
  }
  @keyframes pulse-beat {
    0%, 100% { opacity: 0.45; transform: scale(0.85); }
    50%      { opacity: 1;    transform: scale(1.2);  }
  }

  #pulse .pulse-check {
    flex-shrink: 0;
    width: 28px;
    height: 28px;
    border-radius: 8px;
    background: rgba(201,168,76,0.1);
    border: 1px solid rgba(201,168,76,0.25);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    margin-top: 2px;
  }

  /* Canvas — no box, integrates directly with the section background.
     We keep only the height so the canvas has something to size against. */
  #pulse .pulse-canvas-wrap {
    background: transparent;
    height: 280px;
  }
  @media (min-width: 768px) {
    #pulse .pulse-canvas-wrap { height: 400px; }
  }
  #pulse #pulse-canvas {
    display: block;
    width: 100%;
    height: 100%;
  }

  /* CTA — no box, no border, no rounded corners. A soft vertical gradient
     with a faint gold breath in the middle provides the only visual lift. */
  #pulse .pulse-cta {
    background: linear-gradient(
      180deg,
      transparent 0%,
      rgba(201, 168, 76, 0.05) 50%,
      transparent 100%
    );
    border: none;
    border-radius: 0;
  }
  #pulse .pulse-cta-bg {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 55% 60% at 50% 50%, rgba(201, 168, 76, 0.06), transparent 75%);
    pointer-events: none;
  }

  /* Scroll-in fade */
  #pulse .pulse-bullet,
  #pulse .pulse-metric,
  #pulse .pulse-cta {
    opacity: 0;
    transform: translateY(30px);
    transition: opacity 0.7s ease-out, transform 0.7s ease-out;
    will-change: opacity, transform;
  }
  #pulse .is-visible { opacity: 1; transform: none; }

  @media (max-width: 767px) {
    #pulse .pulse-bullet,
    #pulse .pulse-metric,
    #pulse .pulse-cta {
      opacity: 1;
      transform: none;
      transition: none;
    }
  }
  @media (prefers-reduced-motion: reduce) {
    #pulse .pulse-bullet,
    #pulse .pulse-metric,
    #pulse .pulse-cta,
    #pulse .pulse-dot {
      opacity: 1;
      transform: none;
      transition: none;
      animation: none;
    }
  }
</style>

<script is:inline>
  (function () {
    if (typeof window === 'undefined') return;

    /* ===================================================================
       Part 2 — Canvas swarm
       =================================================================== */
    var canvas = document.getElementById('pulse-canvas');
    var counterEl = document.getElementById('pulse-counter');
    if (!canvas) return;
    var ctx = canvas.getContext('2d');
    var DPR = Math.min(window.devicePixelRatio || 1, 2);
    var NODE_COUNT = 120;
    var CONN_DIST = 100;
    var isMobile = window.innerWidth < 768;
    var LABEL_POOL = ['copy analysis','objection detected','conversion signal','audience match','price sensitivity','message resonance'];

    var nodes = [];
    var pulses = [];
    var floatLabels = [];
    var running = false;
    var raf = 0;
    var lastSingle = 0;
    var lastAnalysis = 0;
    var analysisChain = null;

    function resize() {
      var w = canvas.clientWidth, h = canvas.clientHeight;
      canvas.width = Math.floor(w * DPR);
      canvas.height = Math.floor(h * DPR);
      ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
    }
    function rand(a, b) { return a + Math.random() * (b - a); }

    function initNodes() {
      nodes.length = 0; pulses.length = 0; floatLabels.length = 0;
      var w = canvas.clientWidth, h = canvas.clientHeight;
      for (var i = 0; i < NODE_COUNT; i++) {
        nodes.push({
          x: rand(0, w),
          y: rand(0, h),
          vx: rand(-0.25, 0.25),
          vy: rand(-0.25, 0.25),
          r: rand(1.8, 3),
          active: 0
        });
      }
    }

    function activateNode(i) {
      var n = nodes[i];
      if (!n) return;
      n.active = 1;
      pulses.push({ x: n.x, y: n.y, r: 5, alpha: 0.75 });
      if (!isMobile && Math.random() < 0.65) {
        floatLabels.push({
          x: n.x + rand(10, 22),
          y: n.y + rand(-10, 10),
          text: LABEL_POOL[Math.floor(Math.random() * LABEL_POOL.length)],
          life: 140
        });
      }
    }

    function startAnalysisChain() {
      var seed = Math.floor(Math.random() * nodes.length);
      var target = 8 + Math.floor(Math.random() * 3); // 8–10
      var activated = [seed];
      activateNode(seed);
      analysisChain = { activated: activated, target: target, nextAt: performance.now() + 120 };
    }

    function stepAnalysisChain(now) {
      if (!analysisChain || now < analysisChain.nextAt) return;
      var a = analysisChain;
      if (a.activated.length >= a.target) { analysisChain = null; return; }
      var last = nodes[a.activated[a.activated.length - 1]];
      var best = -1, bestD = Infinity;
      for (var k = 0; k < nodes.length; k++) {
        if (a.activated.indexOf(k) !== -1) continue;
        var dx = nodes[k].x - last.x, dy = nodes[k].y - last.y;
        var d = dx * dx + dy * dy;
        if (d < bestD) { bestD = d; best = k; }
      }
      if (best < 0) { analysisChain = null; return; }
      a.activated.push(best);
      activateNode(best);
      a.nextAt = now + 120;
    }

    function step(ts) {
      if (!running) return;
      var w = canvas.clientWidth, h = canvas.clientHeight;
      ctx.clearRect(0, 0, w, h);

      // Connections
      ctx.lineWidth = 0.5;
      for (var i = 0; i < nodes.length; i++) {
        for (var j = i + 1; j < nodes.length; j++) {
          var a = nodes[i], b = nodes[j];
          var dx = a.x - b.x, dy = a.y - b.y;
          var d = Math.sqrt(dx * dx + dy * dy);
          if (d < CONN_DIST) {
            var alpha = (1 - d / CONN_DIST) * 0.18;
            ctx.strokeStyle = 'rgba(201,168,76,' + alpha + ')';
            ctx.beginPath();
            ctx.moveTo(a.x, a.y);
            ctx.lineTo(b.x, b.y);
            ctx.stroke();
          }
        }
      }

      // Nodes
      for (var ni = 0; ni < nodes.length; ni++) {
        var n = nodes[ni];
        n.x += n.vx; n.y += n.vy;
        if (n.x < 0 || n.x > w) n.vx *= -1;
        if (n.y < 0 || n.y > h) n.vy *= -1;
        if (n.active > 0) n.active = Math.max(0, n.active - 0.012);

        var r = n.r + n.active * 3;
        var op = 0.7 + n.active * 0.3;
        ctx.fillStyle = n.active > 0.5
          ? 'rgba(255,255,255,' + op + ')'
          : 'rgba(201,168,76,' + op + ')';
        if (n.active > 0.3) {
          ctx.shadowColor = 'rgba(255,255,255,0.9)';
          ctx.shadowBlur = 14 * n.active;
        }
        ctx.beginPath();
        ctx.arc(n.x, n.y, r, 0, Math.PI * 2);
        ctx.fill();
        ctx.shadowBlur = 0;
      }

      // Expanding pulse rings
      for (var pi = pulses.length - 1; pi >= 0; pi--) {
        var p = pulses[pi];
        p.r += 1.8;
        p.alpha -= 0.012;
        if (p.alpha <= 0) { pulses.splice(pi, 1); continue; }
        ctx.strokeStyle = 'rgba(201,168,76,' + p.alpha + ')';
        ctx.lineWidth = 1.2;
        ctx.beginPath();
        ctx.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx.stroke();
      }

      // Floating labels (desktop only)
      if (!isMobile && floatLabels.length) {
        ctx.font = '9px Inter, sans-serif';
        ctx.textBaseline = 'middle';
        for (var li = floatLabels.length - 1; li >= 0; li--) {
          var lbl = floatLabels[li];
          lbl.life -= 1;
          lbl.y -= 0.2;
          if (lbl.life <= 0) { floatLabels.splice(li, 1); continue; }
          var la = Math.min(0.45, (lbl.life / 140) * 0.45);
          ctx.fillStyle = 'rgba(201,168,76,' + la + ')';
          ctx.fillText(lbl.text, lbl.x, lbl.y);
        }
      }

      // Triggers
      if (!lastSingle) lastSingle = ts;
      if (!lastAnalysis) lastAnalysis = ts;
      if (ts - lastSingle > 1500) {
        activateNode(Math.floor(Math.random() * nodes.length));
        lastSingle = ts;
      }
      if (ts - lastAnalysis > 4000) {
        startAnalysisChain();
        lastAnalysis = ts;
      }
      stepAnalysisChain(ts);

      raf = requestAnimationFrame(step);
    }

    function start() { if (!running) { running = true; lastSingle = 0; lastAnalysis = 0; raf = requestAnimationFrame(step); } }
    function stop()  { running = false; cancelAnimationFrame(raf); }

    var resizeTimer;
    window.addEventListener('resize', function () {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(function () {
        isMobile = window.innerWidth < 768;
        resize();
        initNodes();
      }, 200);
    });

    resize();
    initNodes();

    // Pause the canvas when offscreen so it doesn't eat CPU.
    var canvasObs = new IntersectionObserver(function (entries) {
      entries.forEach(function (entry) {
        if (entry.isIntersecting) start(); else stop();
      });
    }, { rootMargin: '150px' });
    canvasObs.observe(canvas);

    // Simulated "active agents" counter in the canvas corner.
    var counterVal = 1247;
    setInterval(function () {
      if (!running || !counterEl) return;
      counterVal += Math.round(rand(-25, 25));
      if (counterVal < 1180) counterVal = 1180;
      if (counterVal > 1420) counterVal = 1420;
      counterEl.textContent = String(counterVal);
    }, 700);

    /* ===================================================================
       Part 3 — Animated metrics
       =================================================================== */
    var metricEls = document.querySelectorAll('#pulse .pulse-metric-val');
    var metricsDone = false;

    function animateMetric(el) {
      var target = parseFloat(el.getAttribute('data-target')) || 0;
      var prefix = el.getAttribute('data-prefix') || '';
      var suffix = el.getAttribute('data-suffix') || '';
      var duration = 1700;
      var t0 = performance.now();
      function tick(now) {
        var p = Math.min((now - t0) / duration, 1);
        var eased = 1 - Math.pow(1 - p, 3);
        var v = Math.round(target * eased);
        el.textContent = prefix + v.toLocaleString('en-US') + suffix;
        if (p < 1) requestAnimationFrame(tick);
      }
      requestAnimationFrame(tick);
    }

    if (metricEls.length) {
      var metricRoot = metricEls[0].parentElement && metricEls[0].parentElement.parentElement;
      if (metricRoot) {
        var metricObs = new IntersectionObserver(function (entries) {
          entries.forEach(function (entry) {
            if (entry.isIntersecting && !metricsDone) {
              metricsDone = true;
              metricEls.forEach(animateMetric);
              metricObs.disconnect();
            }
          });
        }, { threshold: 0.4 });
        metricObs.observe(metricRoot);
      }
    }

    /* ===================================================================
       Scroll-in fade for bullets / metrics / CTA (desktop only)
       =================================================================== */
    if (window.innerWidth >= 768 && 'IntersectionObserver' in window) {
      var fadeTargets = document.querySelectorAll('#pulse .pulse-bullet, #pulse .pulse-metric, #pulse .pulse-cta');
      var fadeObs = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (!entry.isIntersecting) return;
          entry.target.classList.add('is-visible');
          fadeObs.unobserve(entry.target);
        });
      }, { rootMargin: '0px 0px -10% 0px' });
      fadeTargets.forEach(function (t, i) {
        t.style.transitionDelay = ((i % 3) * 0.08) + 's';
        fadeObs.observe(t);
      });
    }
  })();
</script>
